    "typecheck": "echo 'TODO Unit 2: tsc --noEmit'",
    "check:trust-anchors": "echo 'TODO Unit 6'",
    "check:fingerprints-disjoint": "echo 'TODO Unit 6'",
    "check:pack": "npx publint && npx @arethetypeswrong/cli --pack ."
  }
}
