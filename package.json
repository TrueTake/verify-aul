{
  "name": "@truetake/verify-aul",
  "version": "0.1.0-alpha.0",
  "description": "Verifier for TrueTake Authorized Use Ledger (AUL) bundles. Pinned trust anchors, RFC 8785 canonicalization, RFC 6962 Merkle proofs, RFC 3161 TSA tokens, Solana memo anchors, Ed25519 signatures.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TrueTake/verify-aul.git"
  },
  "homepage": "https://github.com/TrueTake/verify-aul#readme",
  "bugs": {
    "url": "https://github.com/TrueTake/verify-aul/issues"
  },
  "author": "TrueTake",
  "license": "MIT",
  "keywords": [
    "aul",
    "verification",
    "timestamp",
    "tsa",
    "rfc3161",
    "rfc8785",
    "rfc6962",
    "merkle-proof",
    "ed25519",
    "solana",
    "provenance",
    "audit"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "bin": {
    "verify-aul": "./dist/esm/cli/bin.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/esm/testing.d.ts",
        "default": "./dist/esm/testing.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "src/trust-anchors/*.pem"
  ],
  "tshy": {
    "dialects": [
      "esm"
    ],
    "exports": {
      ".": "./src/index.ts",
      "./testing": "./src/testing.ts",
      "./package.json": "./package.json"
    },
    "exclude": [
      "src/**/*.test.ts",
      "src/cli/**/fixtures/**"
    ],
    "project": "./tsconfig.json"
  },
  "scripts": {
    "build": "tshy",
    "build:web": "node web/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:pack": "publint && attw --pack . --profile esm-only",
    "check:trust-anchors": "tsx scripts/check-trust-anchor-fingerprints.ts",
    "check:fingerprints-disjoint": "tsx scripts/check-fingerprints-disjoint.ts",
    "check:schema-vectors": "tsx scripts/check-schema-vectors.ts",
    "clean": "rm -rf dist .tshy-build web/dist"
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "asn1js": "^3.0.7",
    "canonicalize": "^3.0.0",
    "pkijs": "^3.4.0",
    "pvtsutils": "^1.3.6"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/node": "^22.10.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.24.0",
    "publint": "^0.3.15",
    "tshy": "^4.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  },
  "module": "./dist/esm/index.js"
}
